# ===========================================
# AoE2 LAN Party Analyzer — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# Only API_KEY is required for local dev. Everything else has sensible defaults.

# --- Required in production, optional in dev ---

# Secret key for upload/rebuild endpoints. Clients send this in the X-API-Key header.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# --- Railway Bucket (S3-compatible) — required in production only ---
# These are auto-injected by Railway when a bucket is linked to the service.
# Leave empty for local dev (bucket uploads will be skipped).

AWS_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
# AWS_DEFAULT_REGION is also injected by Railway but not used by our code (boto3 uses endpoint URL instead)

# --- Optional (have sensible defaults) ---

# Base directory for all JSON data files (game_registry.json, player_ratings.json, etc.)
# Default: project root (local dev) or /app/data (Docker/Railway)
# DATA_DIR=

# Port for the Flask/gunicorn server.
# Default: 5050 (local dev). Railway sets this automatically.
# PORT=5050

# Set to "1" to enable Flask debug mode (auto-reload, verbose errors).
# Never enable in production.
# FLASK_DEBUG=0
